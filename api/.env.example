# Copy to `api/.env` for local development (never commit real secrets).
# Gmail account used to send emails
GMAIL_USER=your_gmail@gmail.com

# IMPORTANT: Use a Gmail App Password (not your normal password)
# Create it in Google Account → Security → App passwords
GMAIL_PASS=your_gmail_app_password

# Where you want to receive notifications (defaults to GMAIL_USER)
NOTIFY_TO=your_gmail@gmail.com
